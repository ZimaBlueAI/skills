{
  "_meta": {
    "name": "bump-chart",
    "use_when": "排名随时间变化（≤6 项目）",
    "data_shape": "yAxis 反向，每项一条 line，data 是排名值"
  },
  "tooltip": { "trigger": "axis" },
  "legend": { "top": 0 },
  "grid": { "left": 50, "right": 50, "top": 30, "bottom": 30 },
  "xAxis": {
    "type": "category",
    "data": ["W1","W2","W3","W4","W5","W6","W7","W8"]
  },
  "yAxis": {
    "type": "value",
    "inverse": true,
    "min": 1, "max": 5,
    "interval": 1,
    "axisLabel": { "formatter": "#{value}" }
  },
  "series": [
    { "name": "Mingjing",  "type": "line", "data": [4, 3, 3, 2, 2, 1, 1, 1], "symbolSize": 8, "lineStyle": { "width": 3 } },
    { "name": "ArkClaw",   "type": "line", "data": [1, 1, 2, 1, 1, 2, 2, 2], "symbolSize": 8, "lineStyle": { "width": 3 } },
    { "name": "FinanceX",  "type": "line", "data": [3, 4, 4, 4, 3, 3, 4, 3], "symbolSize": 8, "lineStyle": { "width": 3 } },
    { "name": "Octarus",   "type": "line", "data": [5, 5, 5, 5, 5, 5, 5, 4], "symbolSize": 8, "lineStyle": { "width": 3 } },
    { "name": "Other",     "type": "line", "data": [2, 2, 1, 3, 4, 4, 3, 5], "symbolSize": 8, "lineStyle": { "width": 3 } }
  ]
}
