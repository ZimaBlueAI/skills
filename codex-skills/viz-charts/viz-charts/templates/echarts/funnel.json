      "minSize": "20%", "maxSize": "100%",
      "sort": "descending",
      "gap": 2,
      "label": { "show": true, "position": "inside", "formatter": "{b}\n{c}" },
      "data": [
        { "value": 10000, "name": "访问" },
        { "value": 4200,  "name": "注册" },
        { "value": 2800,  "name": "激活" },
        { "value": 1450,  "name": "首单" },
        { "value": 620,   "name": "复购" }
      ]
    }
  ]
