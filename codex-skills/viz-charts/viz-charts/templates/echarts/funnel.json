{
  "_meta": {
    "name": "funnel",
    "use_when": "转化漏斗，每步留存率",
    "data_shape": "[{name, value}] 按 value 降序"
  },
  "tooltip": { "trigger": "item", "formatter": "{a} <br/>{b}: {c} ({d}%)" },
